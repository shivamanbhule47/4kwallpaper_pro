# Required: Your GitHub repository containing markdown posts
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_POSTS_DIR=posts

# Optional: GitHub Personal Access Token (for private repos or higher API limits)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Site URL for SEO and Open Graph
NEXT_PUBLIC_SITE_URL=https://4kwallpaper.blog
